{
  "expo": {
    "name": "Rnai.io Mobile",
    "slug": "rnai-mobile",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0B3945"
    },
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "io.rnai.mobile",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Rnai uses the microphone to record audio for speech-to-text."
      }
    },
    "android": {
      "package": "io.rnai.mobile",
      "versionCode": 1,
      "permissions": ["android.permission.RECORD_AUDIO", "android.permission.INTERNET"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B3945"
      }
    },
    "plugins": [
      [
        "expo-audio",
        { "microphonePermission": "Rnai uses the microphone to record audio for speech-to-text." }
      ]
    ]
  }
}
