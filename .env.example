# Rnai.io Mobile — public runtime config (bundled into the app at build time).
# Copy to .env and fill in. Only EXPO_PUBLIC_* vars are read by the app.
# Do NOT put backend secrets (Firebase admin, Stripe secret, etc.) here.

# Backend API base URL (your platform). Prod example:
EXPO_PUBLIC_API_URL=https://rnai-io.vercel.app

# Optional failover base URL (self-hosted backup gateway).
EXPO_PUBLIC_API_FALLBACK_URL=

# Default API key used before the user signs in (rnai_sk_...).
# Optional — the app mints a per-user key after login.
EXPO_PUBLIC_API_KEY=

# Self-hosted Rnai LLM base URL (vLLM, OpenAI-compatible). Optional.
EXPO_PUBLIC_RNAI_LLM_URL=
